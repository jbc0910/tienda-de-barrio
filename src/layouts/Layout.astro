---
// Layout.astro - Base layout for all pages
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Tienda de Barrio | Tu Mercado Local Online',
  description = 'Compra en tu tienda de barrio favorita desde tu celular. Productos frescos, domicilio rápido y pago fácil.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#012d1d" />
  <title>{title}</title>

  <!-- Google Fonts: Plus Jakarta Sans + Be Vietnam Pro + Material Symbols -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
    rel="stylesheet"
  />
</head>
<body class="bg-[#f8f9fa] text-[#191c1d]" style="font-family:'Be Vietnam Pro',sans-serif">
  <div class="w-full max-w-[480px] mx-auto min-h-dvh flex flex-col relative overflow-x-hidden">
    <slot />
  </div>
</body>
</html>
