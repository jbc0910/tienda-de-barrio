---
// ProductCard.astro
export interface Props {
  id: string;
  name: string;
  price: number;
  image: string;
  imageAlt: string;
  category?: string;
  stock?: number;
}

const { id, name, price, image, imageAlt, category = '', stock = 10 } = Astro.props;
const formattedPrice = new Intl.NumberFormat('es-CO', {
  style: 'currency',
  currency: 'COP',
  minimumFractionDigits: 0,
}).format(price);
---

<article
  class="product-card bg-[#ffffff] rounded-2xl shadow-card border border-[#c1c8c2]/20 overflow-hidden flex flex-col transition-transform duration-200 hover:scale-[1.02] hover:shadow-elevated"
  data-product-id={id}
  data-product-name={name}
  data-product-price={price}
  data-product-image={image}
>
  <!-- Image -->
  <div class="aspect-square bg-[#f3f4f5] relative overflow-hidden">
    <img
      src={image}
      alt={imageAlt}
      title={name}
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
    />
    {stock <= 0 && (
      <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
        <span class="text-white text-xs font-bold uppercase bg-[#ba1a1a] px-2 py-1 rounded">Agotado</span>
      </div>
    )}
    {stock > 0 && stock <= 3 && (
      <div class="absolute top-2 left-2 bg-yellow-400 text-yellow-900 text-[10px] font-bold px-2 py-0.5 rounded-full">
        ¡Últimas {stock}!
      </div>
    )}
  </div>

  <!-- Info -->
  <div class="p-3 flex-1 flex flex-col justify-between gap-2">
    <div>
      <p class="text-[10px] text-[#717973] uppercase font-semibold tracking-wide">{category}</p>
      <h3 class="text-[14px] font-semibold leading-tight text-[#191c1d] mt-0.5 line-clamp-2">{name}</h3>
      <p class="text-primary text-[18px] font-bold leading-tight mt-1">{formattedPrice}</p>
    </div>

    <!-- Quantity Control -->
    <div class="qty-control flex items-center justify-between bg-[#e7e8e9] rounded-xl p-1 mt-1">
      <button
        class="qty-minus w-9 h-9 flex items-center justify-center bg-[#ffffff] rounded-lg text-[#012d1d] shadow-sm active:scale-90 transition-all"
        aria-label={`Disminuir cantidad de ${name}`}
        title={`Disminuir cantidad de ${name}`}
      >
        <span class="material-symbols-outlined text-[18px]">remove</span>
      </button>

      <span class="qty-value font-bold text-[16px] text-[#191c1d] w-6 text-center">0</span>

      <button
        class="qty-plus w-9 h-9 flex items-center justify-center bg-[#012d1d] text-white rounded-lg shadow-sm active:scale-90 transition-all"
        aria-label={`Aumentar cantidad de ${name}`}
        title={`Aumentar cantidad de ${name}`}
      >
        <span class="material-symbols-outlined text-[18px]">add</span>
      </button>
    </div>
  </div>
</article>

<script>
  // ProductCard hydration — runs once per card on mount
  document.querySelectorAll<HTMLElement>('.product-card').forEach((card) => {
    const id    = card.dataset.productId!;
    const name  = card.dataset.productName!;
    const price = Number(card.dataset.productPrice);
    const image = card.dataset.productImage!;

    const minusBtn = card.querySelector<HTMLButtonElement>('.qty-minus')!;
    const plusBtn  = card.querySelector<HTMLButtonElement>('.qty-plus')!;
    const qtyEl    = card.querySelector<HTMLElement>('.qty-value')!;

    // Restore from cart state
    const cart = getCart();
    const item = cart.find((i: CartItem) => i.id === id);
    if (item) qtyEl.textContent = String(item.qty);

    minusBtn.addEventListener('click', () => {
      const qty = Math.max(0, parseInt(qtyEl.textContent || '0') - 1);
      qtyEl.textContent = String(qty);
      updateCart({ id, name, price, image, qty });
    });

    plusBtn.addEventListener('click', () => {
      const qty = parseInt(qtyEl.textContent || '0') + 1;
      qtyEl.textContent = String(qty);
      updateCart({ id, name, price, image, qty });
    });
  });

  interface CartItem { id: string; name: string; price: number; image: string; qty: number }

  function getCart(): CartItem[] {
    try { return JSON.parse(localStorage.getItem('tienda_cart') || '[]'); }
    catch { return []; }
  }

  function saveCart(cart: CartItem[]) {
    localStorage.setItem('tienda_cart', JSON.stringify(cart));
    dispatchEvent(new CustomEvent('cart-updated', { detail: cart }));
  }

  function updateCart(item: CartItem) {
    let cart = getCart();
    const idx = cart.findIndex((i) => i.id === item.id);
    if (item.qty === 0) {
      cart = cart.filter((i) => i.id !== item.id);
    } else if (idx >= 0) {
      cart[idx] = item;
    } else {
      cart.push(item);
    }
    saveCart(cart);
  }
</script>
